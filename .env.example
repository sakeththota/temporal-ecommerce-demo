# Caddy - set to :80 for local, or your domain (e.g. temporaldemo.skth.dev) for production
CADDY_DOMAIN=:80

# Temporal UI - set to :8233 for local, or your subdomain (e.g. temporalui.skth.dev) for production
TEMPORAL_DOMAIN=:8233

# Temporal UI URL - used by the frontend to link to Temporal UI
# Local: http://localhost:8233, Production: https://temporalui.skth.dev
TEMPORAL_UI_URL=http://localhost:8233

# PostHog analytics
POSTHOG_KEY=phc_your_posthog_key_here
